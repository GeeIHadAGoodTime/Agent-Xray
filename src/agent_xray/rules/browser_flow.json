{
  "name": "browser_flow",
  "description": "Commerce and navigation-oriented grading rules with full Viola parity. Rewards URL progression, milestone reach, and meaningful fills. Uses exclusive spin and error-rate tiers.",
  "signals": [
    {
      "name": "url_progression",
      "metric": "unique_urls",
      "gte": 3,
      "points": 2,
      "reason": "+2 URL progression ({actual} pages)"
    },
    {
      "name": "navigation_progress",
      "metric": "unique_url_paths",
      "gte": 2,
      "points": 1,
      "else_points": -1,
      "reason": "+1 navigated multiple pages",
      "else_reason": "-1 stuck on single page or no navigation"
    },
    {
      "name": "checkout_reached",
      "metric": "commerce.reached_checkout",
      "equals": true,
      "points": 3,
      "reason": "+3 checkout reached"
    },
    {
      "name": "payment_reached",
      "metric": "commerce.reached_payment",
      "equals": true,
      "points": 4,
      "reason": "+4 payment reached"
    },
    {
      "name": "cart_reached",
      "metric": "commerce.reached_cart",
      "equals": true,
      "points": 2,
      "reason": "+2 cart reached"
    },
    {
      "name": "real_fills",
      "metric": "commerce.real_fill_count",
      "gte": 1,
      "points": 2,
      "reason": "+2 real form fills"
    },
    {
      "name": "any_fills",
      "metric": "commerce.fill_count",
      "gte": 1,
      "points": 1,
      "reason": "+1 form fill attempted"
    },
    {
      "name": "tool_diversity",
      "metric": "unique_tools",
      "gte": 3,
      "points": 1,
      "reason": "+1 tool diversity"
    },
    {
      "name": "healthy_step_range",
      "metric": "healthy_step_range",
      "equals": true,
      "points": 1,
      "reason": "+1 healthy step count (8-25)"
    },
    {
      "name": "zero_errors",
      "metric": "errors",
      "equals": 0,
      "points": 1,
      "reason": "+1 zero errors"
    },
    {
      "name": "timeout_penalty",
      "metric": "timeout_like",
      "equals": true,
      "points": -4,
      "reason": "-4 timeout"
    },
    {
      "name": "severe_spin",
      "metric": "spin_is_severe",
      "equals": true,
      "points": -4,
      "reason": "-4 severe spin (10+ repeats)"
    },
    {
      "name": "moderate_spin",
      "metric": "spin_is_moderate",
      "equals": true,
      "points": -2,
      "reason": "-2 moderate spin (5-9 repeats)"
    },
    {
      "name": "mild_spin",
      "metric": "spin_is_mild",
      "equals": true,
      "points": -1,
      "reason": "-1 mild spin (3-4 repeats)"
    },
    {
      "name": "high_error_rate",
      "metric": "error_rate_is_high",
      "equals": true,
      "points": -3,
      "reason": "-3 error rate above 50%"
    },
    {
      "name": "medium_error_rate",
      "metric": "error_rate_is_medium",
      "equals": true,
      "points": -1,
      "reason": "-1 error rate above 20%"
    },
    {
      "name": "suspiciously_short",
      "metric": "commerce.suspiciously_short",
      "equals": true,
      "points": -3,
      "reason": "-3 suspiciously short (1-2 steps to payment)"
    },
    {
      "name": "stuck_on_page",
      "metric": "unique_urls",
      "lte": 1,
      "points": -2,
      "reason": "-2 stayed on one page"
    },
    {
      "name": "hallucination_penalty",
      "metric": "hallucinated_tools",
      "gte": 2,
      "points": -2,
      "reason": "-2 hallucinated tools"
    },
    {
      "name": "routing_penalty",
      "metric": "no_tools_steps",
      "gte": 1,
      "points": -1,
      "reason": "-1 step(s) with zero tools available"
    }
  ],
  "grade_thresholds": {
    "GOLDEN": 8,
    "GOOD": 5,
    "OK": 2,
    "WEAK": 0
  },
  "golden_requirements": [
    {
      "metric": "commerce.payment_fields_confirmed",
      "equals": true,
      "reason": "~0 capped at GOOD: payment details were not visibly confirmed"
    },
    {
      "metric": "commerce.url_has_terminal",
      "equals": true,
      "reason": "~0 capped at GOOD: terminal payment URL was never reached"
    }
  ]
}
