{
  "name": "default",
  "description": "Generic grading rules for any agent trace. Focuses on reliability, progress, and loop resistance.",
  "philosophy": "The default ruleset grades EXECUTION QUALITY — tool diversity, reliability, and loop resistance. It does NOT verify task achievement. Self-reported success earns +1, not +2, because the agent's word alone cannot prove the task was accomplished. For domain-specific achievement grading, use browser_flow, coding_agent, or research_agent rulesets, or create your own with 'agent-xray rules init'.",
  "signals": [
    {
      "name": "tool_diversity",
      "metric": "unique_tools",
      "gte": 3,
      "points": 1,
      "reason": "+1 tool diversity ({actual} distinct tools)"
    },
    {
      "name": "healthy_step_count",
      "metric": "step_count",
      "gte": 4,
      "points": 1,
      "reason": "+1 made a non-trivial attempt ({actual} steps)"
    },
    {
      "field": "step_count",
      "op": "lte",
      "value": 0,
      "points": -5,
      "label": "empty_task"
    },
    {
      "name": "zero_errors",
      "metric": "errors",
      "equals": 0,
      "points": 1,
      "reason": "+1 zero errors"
    },
    {
      "name": "task_completed",
      "metric": "task_completed",
      "equals": true,
      "points": 1,
      "reason": "+1 task completed (self-reported)"
    },
    {
      "name": "timeout_penalty",
      "metric": "timeout_like",
      "equals": true,
      "points": -4,
      "reason": "-4 timeout or max-iteration termination"
    },
    {
      "name": "spin_penalty",
      "metric": "max_repeat_count",
      "gte": 5,
      "points": -2,
      "reason": "-2 repeated one tool {actual} times"
    },
    {
      "name": "severe_spin_penalty",
      "metric": "max_repeat_count",
      "gte": 10,
      "points": -2,
      "reason": "-2 severe repetition ({actual})"
    },
    {
      "name": "error_rate_penalty",
      "metric": "error_rate",
      "gt": 0.5,
      "points": -3,
      "reason": "-3 error rate above 50%"
    },
    {
      "name": "hallucination_penalty",
      "metric": "hallucinated_tools",
      "gte": 2,
      "points": -2,
      "reason": "-2 hallucinated tool calls ({actual})"
    },
    {
      "name": "routing_penalty",
      "metric": "no_tools_steps",
      "gte": 1,
      "points": -1,
      "reason": "-1 at least one step had zero tools available"
    },
    {
      "name": "suspicious_short_penalty",
      "metric": "suspicious_short_flag",
      "equals": true,
      "points": -1,
      "reason": "-1 task flagged as suspiciously short by runtime"
    }
  ],
  "grade_thresholds": {
    "GOLDEN": 4,
    "GOOD": 3,
    "OK": 1,
    "WEAK": 0
  },
  "golden_requirements": [
    {
      "field": "max_repeat_count",
      "op": "lt",
      "value": 3,
      "reason": "GOLDEN requires no tool repeated 3+ times consecutively"
    },
    {
      "field": "suspicious_short_flag",
      "op": "equals",
      "value": false,
      "reason": "GOLDEN cannot be suspiciously short"
    }
  ]
}
